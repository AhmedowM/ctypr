PROJECT_NAME           = "ctypr"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "C typing practice library"
OUTPUT_DIRECTORY        = @CMAKE_CURRENT_BINARY_DIR@/docs
INPUT                  = @PROJECT_SOURCE_DIR@/src @PROJECT_SOURCE_DIR@/docs
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = @PROJECT_SOURCE_DIR@/docs/index.md
SOURCE_BROWSER         = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_STATIC         = NO
EXTRACT_PRIVATE        = NO
MACRO_EXPANSION        = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = @PROJECT_SOURCE_DIR@/docs/doxygen-awesome.css
HTML_EXTRA_FILES       = @PROJECT_SOURCE_DIR@/docs/doxygen-awesome-darkmode-toggle.js
HTML_FOOTER            = @PROJECT_SOURCE_DIR@/docs/footer.html
